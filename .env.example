# --- Base de datos / infra ---
DATABASE_URL=postgresql+psycopg://quotebot:quotebot@localhost:5432/quotebot
REDIS_URL=redis://localhost:6379/0

# --- LLM: cualquier proveedor via LiteLLM ---
# Roles: parser_fallback | matcher | extractor_fallback | query_reformulator
PARSER_FALLBACK_MODEL=anthropic/claude-sonnet-4-5
MATCHER_MODEL=deepseek/deepseek-chat
EXTRACTOR_FALLBACK_MODEL=deepseek/deepseek-chat
QUERY_REFORMULATOR_MODEL=deepseek/deepseek-chat

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=

# --- Busqueda ---
SERPER_API_KEY=
EBAY_APP_ID=
ALIEXPRESS_APP_KEY=
ALIEXPRESS_APP_SECRET=

# --- Logica de negocio ---
OPTIONS_PER_ITEM=4
EQUIVALENCE_THRESHOLD=0.7
MAX_REFORMULATIONS_PER_TIER=2
MAX_SEARCHES_PER_ITEM=18
CANDIDATES_TO_MATCHER=10
TIER_ORDER=ve,us,cn,global

# --- Correo ---
POLL_INTERVAL_MINUTES=15
GMAIL_CREDENTIALS_JSON=secrets/gmail_credentials.json
GMAIL_TOKEN_JSON=secrets/gmail_token.json
QUOTE_SUBJECT_KEYWORDS=cotizacion,cotización,rfq,solicitud de compra
QUOTE_SENDER_WHITELIST=
